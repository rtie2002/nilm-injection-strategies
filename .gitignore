# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Large data files (copy separately to other machines)
*.npz
*.npy
injection_strategy/datasets/**/*.csv
data/**/*.csv

# Training outputs (recreated when you train; .gitkeep keeps folder structure)
checkpoints/*
!checkpoints/.gitkeep
figures/*
!figures/.gitkeep
results/*
!results/.gitkeep
*.pt
*.h5

# Geng et al. reference repo (DiffusionModel_NILM) — code only, not data/weights
DiffusionModel_NILM/OUTPUT/
DiffusionModel_NILM/.Checkpoints/
DiffusionModel_NILM/Data/datasets/*.csv
DiffusionModel_NILM/**/created_data/**/*.csv
DiffusionModel_NILM/generatedData/**/*.csv
*.pdf
*.png

# IDE / OS
.idea/
.vscode/
*.swp
Thumbs.db
.Desktop
